<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.quanta.frontend</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>scripts/ops_entrypoint.sh</string>
    <string>frontend</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/carpon/web/QuantA</string>

  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/Users/carpon/web/QuantA/data/logs/launchd-frontend.stdout.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/carpon/web/QuantA/data/logs/launchd-frontend.stderr.log</string>
</dict>
</plist>
