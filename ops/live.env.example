# Copy this file to data/env/live.env on the host that runs QuantA.
# Do not commit the real token file.

QUANTA_SOURCE_PROVIDER=tushare
QUANTA_TUSHARE_TOKEN=replace-with-your-token
QUANTA_SOURCE_UNIVERSE=core_operating_40

# Start with no supplementary validators for unattended canonical catch-up.
# Re-enable akshare/baostock shadow validation after the primary daily path is stable.
QUANTA_SOURCE_VALIDATION_PROVIDERS=none

QUANTA_HISTORY_BACKFILL_TARGET_START_BIZ_DATE=auto
QUANTA_HISTORY_BACKFILL_TARGET_OPEN_DAYS=80
QUANTA_SCHEDULER_POLL_INTERVAL_SECONDS=30

QUANTA_BACKEND_HOST=127.0.0.1
QUANTA_BACKEND_PORT=8765
QUANTA_FRONTEND_HOST=127.0.0.1
QUANTA_FRONTEND_PORT=4173
